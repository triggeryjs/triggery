{
  "name": "@triggery/solid",
  "version": "0.10.0",
  "description": "SolidJS bindings for Triggery — same useEvent / useCondition / useAction surface as React, native to signals + onCleanup. Zero runtime dependencies.",
  "license": "MIT",
  "author": "Aleksey Skhomenko",
  "homepage": "https://triggeryjs.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triggeryjs/triggery.git",
    "directory": "packages/solid"
  },
  "bugs": "https://github.com/triggeryjs/triggery/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/triggery"
    },
    {
      "type": "boosty",
      "url": "https://boosty.to/triggery"
    }
  ],
  "keywords": [
    "triggery",
    "solid",
    "solidjs",
    "bindings",
    "orchestration"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@triggery/core": "workspace:*",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@triggery/core": "workspace:*",
    "happy-dom": "^20.9.0",
    "solid-js": "^1.9.13",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.6"
  },
  "llms": "https://triggeryjs.github.io/llms.txt",
  "llmsFull": "https://triggeryjs.github.io/llms-full.txt"
}
