{
  "name": "@triggery/redux",
  "version": "0.0.0",
  "description": "Redux adapter for Triggery \u2014 read store state from a trigger condition without subscribing the component to re-renders",
  "license": "MIT",
  "author": "Aleksey Skhomenko",
  "homepage": "https://triggeryjs.github.io/triggery",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triggeryjs/triggery.git",
    "directory": "packages/redux"
  },
  "bugs": "https://github.com/triggeryjs/triggery/issues",
  "funding": [
    {
      "type": "boosty",
      "url": "https://boosty.to/triggery"
    }
  ],
  "keywords": [
    "triggery",
    "redux",
    "adapter",
    "react",
    "state"
  ],
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@triggery/core": "workspace:*",
    "@triggery/react": "workspace:*",
    "react": ">=18.0.0",
    "redux": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@triggery/core": "workspace:*",
    "@triggery/react": "workspace:*",
    "@types/react": "^19.2.14",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "redux": "^5.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
