{
  "name": "@triggery/core",
  "version": "1.0.0",
  "description": "Declarative business-logic orchestration — framework-agnostic runtime (React, Solid, Vue, or any binding you write). Zero runtime dependencies.",
  "license": "MIT",
  "author": "Aleksey Skhomenko",
  "homepage": "https://triggeryjs.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triggeryjs/triggery.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/triggeryjs/triggery/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/triggery"
    },
    {
      "type": "boosty",
      "url": "https://boosty.to/triggery"
    }
  ],
  "keywords": [
    "triggers",
    "events",
    "orchestration",
    "business-logic",
    "rule-engine",
    "side-effects",
    "framework-agnostic",
    "react",
    "solid",
    "vue",
    "zero-dependencies"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": {
        "production": "./dist/index.prod.js",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./inspect": {
      "source": "./src/inspect.ts",
      "types": "./dist/inspect.d.ts",
      "import": {
        "production": "./dist/inspect.prod.js",
        "default": "./dist/inspect.js"
      },
      "default": "./dist/inspect.js"
    },
    "./builder": {
      "source": "./src/builder.ts",
      "types": "./dist/builder.d.ts",
      "import": {
        "production": "./dist/builder.prod.js",
        "default": "./dist/builder.js"
      },
      "default": "./dist/builder.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "llms": "https://triggeryjs.github.io/llms.txt",
  "llmsFull": "https://triggeryjs.github.io/llms-full.txt"
}
