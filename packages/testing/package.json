{
  "name": "@triggery/testing",
  "version": "0.9.1",
  "description": "Testing utilities for Triggery \u2014 isolated runtime, fake scheduler, mock conditions/actions. Zero runtime dependencies, works with Vitest / Jest / node:test.",
  "license": "MIT",
  "author": "Aleksey Skhomenko",
  "homepage": "https://triggeryjs.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triggeryjs/triggery.git",
    "directory": "packages/testing"
  },
  "bugs": "https://github.com/triggeryjs/triggery/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/triggery"
    },
    {
      "type": "boosty",
      "url": "https://boosty.to/triggery"
    }
  ],
  "keywords": [
    "triggery",
    "testing",
    "vitest",
    "jest",
    "node-test",
    "mocking",
    "fake-timers",
    "zero-dependencies",
    "framework-agnostic"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@triggery/core": "workspace:*"
  },
  "devDependencies": {
    "@triggery/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "llms": "https://triggeryjs.github.io/llms.txt",
  "llmsFull": "https://triggeryjs.github.io/llms-full.txt"
}
