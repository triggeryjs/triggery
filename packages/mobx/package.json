{
  "name": "@triggery/mobx",
  "version": "0.10.0",
  "description": "MobX adapter for Triggery — read observable state from a trigger condition with no reaction setup",
  "license": "MIT",
  "author": "Aleksey Skhomenko",
  "homepage": "https://triggeryjs.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triggeryjs/triggery.git",
    "directory": "packages/mobx"
  },
  "bugs": "https://github.com/triggeryjs/triggery/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/triggery"
    },
    {
      "type": "boosty",
      "url": "https://boosty.to/triggery"
    }
  ],
  "keywords": [
    "triggery",
    "mobx",
    "adapter",
    "react",
    "observable"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@triggery/core": "workspace:*",
    "@triggery/react": "workspace:*",
    "mobx": "^6.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@triggery/core": "workspace:*",
    "@triggery/react": "workspace:*",
    "@types/react": "^19.2.15",
    "happy-dom": "^20.9.0",
    "mobx": "^6.15.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "llms": "https://triggeryjs.github.io/llms.txt",
  "llmsFull": "https://triggeryjs.github.io/llms-full.txt"
}
