{
  "name": "@triggery/cli",
  "version": "0.1.2",
  "description": "Command-line interface for Triggery — create, scaffold, graph, lint.",
  "license": "MIT",
  "author": "Aleksey Skhomenko",
  "homepage": "https://triggeryjs.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triggeryjs/triggery.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/triggeryjs/triggery/issues",
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/triggery"
    },
    {
      "type": "boosty",
      "url": "https://boosty.to/triggery"
    }
  ],
  "keywords": [
    "triggery",
    "cli",
    "scaffold",
    "create",
    "graph"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "triggery": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "giget": "^1.2.3",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "llms": "https://triggeryjs.github.io/llms.txt",
  "llmsFull": "https://triggeryjs.github.io/llms-full.txt"
}
