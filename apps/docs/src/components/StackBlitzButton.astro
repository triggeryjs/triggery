---
/**
 * "Open in StackBlitz" CTA.
 *
 * By default fetches a build-time-pre-bundled JSON snapshot of the example
 * folder and opens it via `@stackblitz/sdk`'s `openProject({ files })`.
 * This boots StackBlitz with the files **inlined** — no `git clone` of the
 * 47 MB monorepo, so the editor mounts in 1-2 seconds instead of 30-60.
 *
 * Falls back to the classic `stackblitz.com/github/<owner>/<repo>/...` URL
 * if the bundle is unavailable for any reason (older deploy, JSON 404, SDK
 * import failure). The `href` attribute is always set so the link works
 * with JS disabled and middle-click "open in new tab".
 */
interface Props {
  /** Path inside the monorepo, e.g. "examples/vite-react-counter". */
  path: string;
  /** Override the link text. */
  label?: string;
  /** Branch (default: main) for the fallback GitHub URL. */
  ref?: string;
}

const { path, label = 'Open in StackBlitz', ref = 'main' } = Astro.props;

// Extract the bare example name (last segment) — used to locate the
// pre-bundled JSON under /example-bundles/.
const name = path.split('/').filter(Boolean).pop() ?? path;

// Fallback URL when the bundle can't be loaded.
const href = `https://stackblitz.com/github/triggeryjs/triggery/tree/${ref}/${path}?file=README.md`;
const bundleUrl = `/example-bundles/${name}.json`;
---

<a class="sb-btn" href={href} data-sb-bundle={bundleUrl} target="_blank" rel="noreferrer noopener">
  <svg viewBox="0 0 28 28" width="18" height="18" aria-hidden="true">
    <path fill="#1389FD" d="M11.063 18.586H4l11.834-12.586-3 8h7L8 26.586l3.063-8z" />
  </svg>
  <span>{label}</span>
</a>

<script>
  // One listener per page handles every <a.sb-btn[data-sb-bundle]> instance.
  // Lazy-imports the SDK on first click so non-clickers don't pay the cost.
  document.querySelectorAll<HTMLAnchorElement>('a.sb-btn[data-sb-bundle]').forEach((a) => {
    a.addEventListener('click', async (e) => {
      const bundleUrl = a.dataset.sbBundle;
      if (!bundleUrl) return;
      e.preventDefault();
      try {
        const [{ default: sdk }, res] = await Promise.all([
          import('@stackblitz/sdk'),
          fetch(bundleUrl),
        ]);
        if (!res.ok) throw new Error(`bundle ${bundleUrl}: ${res.status}`);
        const bundle = (await res.json()) as {
          name: string;
          title?: string;
          description?: string;
          files: Record<string, string>;
        };
        sdk.openProject(
          {
            title: bundle.title ?? bundle.name,
            description: bundle.description ?? '',
            template: 'node',
            files: bundle.files,
          },
          { openFile: 'README.md', newWindow: true },
        );
      } catch (err) {
        // Fall back to the GitHub URL so the user still ends up in StackBlitz.
        console.warn('StackBlitz inline open failed, falling back to GitHub URL:', err);
        window.open(a.href, '_blank', 'noreferrer,noopener');
      }
    });
  });
</script>

<style>
  .sb-btn {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    vertical-align: top;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: #1389fd;
    color: #fff;
    font-weight: 600;
    border-radius: 0.4rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition: filter 0.15s ease;
  }
  .sb-btn:hover {
    filter: brightness(1.08);
    text-decoration: none;
  }
  .sb-btn svg path {
    fill: #fff;
  }
</style>
