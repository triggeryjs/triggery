---
/**
 * "Open in StackBlitz" CTA. Targets a directory in the triggeryjs/triggery
 * repo via StackBlitz's `~/github` URL. Use this in Examples pages and
 * recipes that have a runnable companion in `examples/`.
 */
interface Props {
  /** Path inside the monorepo, e.g. "examples/vite-react-counter". */
  path: string;
  /** Override the link text. */
  label?: string;
  /** Branch (default: main). */
  ref?: string;
}

const { path, label = 'Open in StackBlitz', ref = 'main' } = Astro.props;
const href = `https://stackblitz.com/github/triggeryjs/triggery/tree/${ref}/${path}?file=README.md`;
---

<a class="sb-btn" href={href} target="_blank" rel="noreferrer noopener">
  <svg viewBox="0 0 28 28" width="18" height="18" aria-hidden="true">
    <path fill="#1389FD" d="M11.063 18.586H4l11.834-12.586-3 8h7L8 26.586l3.063-8z"/>
  </svg>
  <span>{label}</span>
</a>

<style>
  .sb-btn {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: #1389fd;
    color: #fff;
    font-weight: 600;
    border-radius: 0.4rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition: filter 0.15s ease;
  }
  .sb-btn:hover {
    filter: brightness(1.08);
    text-decoration: none;
  }
  .sb-btn svg path {
    fill: #fff;
  }
</style>
