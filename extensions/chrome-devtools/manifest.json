{
  "manifest_version": 3,
  "name": "Triggery DevTools",
  "version": "0.1.0",
  "description": "Inspect Triggery runtime events live from Chrome DevTools.",
  "minimum_chrome_version": "108",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
